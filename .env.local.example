# Copie este arquivo para .env.local e preencha com seus IDs reais.
# Na Vercel: Settings > Environment Variables (adicionar cada uma e fazer redeploy).
# Sem esses valores, as tags simplesmente não carregam (sem erros).

# Google Analytics 4 (formato: G-XXXXXXXXXX)
# Criar em: analytics.google.com > Administrador > Criar propriedade
NEXT_PUBLIC_GA4_ID=

# Google Ads — ID da tag (formato: AW-XXXXXXXXXX)
# Em: Google Ads > Ferramentas > Metas > Conversões > nova ação "Clique no WhatsApp"
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads — rótulo da ação de conversão principal "Clique no WhatsApp"
# (formato: AW-XXXXXXXXXX/AbCdEfGhIj — aparece no snippet como "send_to")
NEXT_PUBLIC_ADS_CONVERSION_LABEL=

# Google Ads — rótulo da ação "Clique no WhatsApp — Piercing" (opcional;
# sem ele, cliques de piercing contam na ação principal)
NEXT_PUBLIC_ADS_CONVERSION_LABEL_PIERCING=

# Meta Pixel / Facebook Pixel (somente números)
NEXT_PUBLIC_PIXEL_ID=
